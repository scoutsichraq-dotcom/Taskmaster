{
  "name": "taskmaster-pro",
  "private": true,
  "version": "1.0.0",
  "description": "Production-grade Task Management Desktop Application",
  "author": "TaskMaster Team",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run serve\" \"npm run electron:dev\" --kill-others",
    "serve": "tsx server.ts",
    "electron:dev": "wait-on http://localhost:5000 && cross-env NODE_ENV=development electron .",
    "build": "npm run build:vite",
    "build:vite": "vite build",
    "build:electron": "npm run build:vite && cross-env NODE_ENV=production electron-builder",
    "dist": "npm run build:electron",
    "dist:win": "npm run build:vite && cross-env NODE_ENV=production electron-builder --win --publish never",
    "dist:mac": "npm run build:vite && cross-env NODE_ENV=production electron-builder --mac --publish never",
    "dist:linux": "npm run build:vite && cross-env NODE_ENV=production electron-builder --linux --publish never",
    "dist:all": "npm run build:vite && cross-env NODE_ENV=production electron-builder -mwl",
    "preview": "vite preview",
    "clean": "rm -rf dist out",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "com.taskmaster-pro.app",
    "productName": "TaskMaster Pro",
    "directories": {
      "buildResources": "public/assets",
      "output": "out"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "scoutsichraq-dotcom",
        "repo": "Taskmaster"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "./public/assets/icon.png",
      "uninstallerIcon": "./public/assets/icon.png",
      "installerHeaderIcon": "./public/assets/icon.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Productivity"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    }
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.4.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "i18next": "^25.8.14",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.4"
  }
}
